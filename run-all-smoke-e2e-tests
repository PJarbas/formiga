#!/usr/bin/env bash
# Run the FAST Formiga smoke / state-machine integration e2e tests.
#
# This is the DEFAULT e2e test script. It exercises the workflow state
# machine, pipeline wiring, and step lifecycle using manual step advance
# (claim/complete with canned outputs). No real agents, models, or
# schedulers are invoked. Expects to complete in ~10-15 seconds.
#
# For the SLOW real end-to-end test that runs actual agent invocations:
#   ./run-all-real-e2e-tests
#
# Output is streamed to the terminal AND tee'd to a log file for inspection.
# Exit code matches the underlying `node --test` exit code.
set -euo pipefail
cd "$(dirname "$0")"

LOG="${FORMIGA_SMOKE_E2E_LOG:-e2e-smoke-test-output.log}"

npm run build
node --test e2e-tests/workflows-smoke.test.ts 2>&1 | tee "$LOG"
exit "${PIPESTATUS[1]}"
