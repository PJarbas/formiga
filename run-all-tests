#!/usr/bin/env bash
# Build and run the full Formiga test suite (unit + integration).
# End-to-end tests live under e2e-tests/ and are NOT included here.
# To run end-to-end tests, use ./run-all-e2e-tests instead.
# Output is streamed to the terminal AND tee'd to test-output.log for inspection.
# Exit code matches the underlying `npm test` exit code.
set -euo pipefail
cd "$(dirname "$0")"

LOG="${FORMIGA_TEST_LOG:-test-output.log}"

npm run build
npm test 2>&1 | tee "$LOG"
exit "${PIPESTATUS[1]}"
