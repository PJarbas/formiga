#!/usr/bin/env bash
# Build and run the Tamandua end-to-end test suite.
# End-to-end tests live under e2e-tests/ and are separate from the regular
# unit/integration test suite (tests/ + src/**/*.test.ts).
# Output is streamed to the terminal AND tee'd to e2e-test-output.log for inspection.
# Exit code matches the underlying `node --test` exit code.
set -euo pipefail
cd "$(dirname "$0")"

LOG="${TAMANDUA_E2E_TEST_LOG:-e2e-test-output.log}"

npm run build
node --test e2e-tests/*.test.ts 2>&1 | tee "$LOG"
exit "${PIPESTATUS[1]}"
