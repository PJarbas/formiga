#!/bin/bash
# Build from source, then install globally.
# Convenience wrapper — equivalent to: ./build && ./install
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

echo ">>> Step 1/2: build"
"$SCRIPT_DIR/build"

echo ""
echo ">>> Step 2/2: install"
"$SCRIPT_DIR/install"
